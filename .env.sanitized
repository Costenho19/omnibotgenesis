# ========================================
# OMNIX V6.0 ULTRA - Environment Variables
# ========================================
# Este archivo muestra cómo debería verse .env sin credenciales reales
# ⚠️ NUNCA subir credenciales reales al repositorio
# ✅ Usar Replit Secrets (producción) o .env.local (desarrollo)

# ========================================
# TELEGRAM (REQUIRED)
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_USER_ID=your_telegram_user_id_here

# ========================================
# AI APIS (At least one required)
# ========================================
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Optional

# ========================================
# TRADING APIS (For live trading)
# ========================================
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
# ALPACA_API_KEY=your_alpaca_api_key_here  # For stock trading
# ALPACA_API_SECRET=your_alpaca_api_secret_here

# ========================================
# DATABASE
# ========================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  # Auto-provided by Replit/Railway
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # If needed

# ========================================
# SECURITY
# ========================================
SESSION_SECRET=generate-a-random-32-char-secret-key-here-for-sessions
ENCRYPTION_KEY=generate-another-32-char-key-here-for-encryption
SECRET_KEY=omnix-enterprise-secret-key-change-in-production

# ========================================
# APP SETTINGS
# ========================================
PORT=8000
HOST=0.0.0.0
STOCK_TRADING_ENABLED=true
PAPER_MODE=true
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false

# ========================================
# MONITORING
# ========================================
ENABLE_METRICS=true
METRICS_PORT=9090
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx  # Optional

# ========================================
# CELERY (If using background workers)
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================================
# ROTACIÓN DE CREDENCIALES REQUERIDA
# ========================================
# ⚠️ Las siguientes credenciales DEBEN ser rotadas si estuvieron expuestas:
#
# 1. TELEGRAM_BOT_TOKEN - Regenerar en @BotFather
# 2. KRAKEN_API_KEY/SECRET - Regenerar en Kraken Security Settings
# 3. GEMINI_API_KEY - Regenerar en Google Cloud Console
# 4. OPENAI_API_KEY - Regenerar en OpenAI Dashboard
#
# Ver MIGRATION_GUIDE.md para instrucciones detalladas
