# =============================================================================
# OMNIX V6.0 ULTRA - Environment Variables Template
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env.local (NO commitear .env.local a git)
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. En producción, usa Replit Secrets en lugar de .env.local
#
# PRECEDENCIA: Replit Secrets > .env.local > valores por defecto
# =============================================================================

# =============================================================================
# 📱 TELEGRAM BOT (REQUIRED)
# =============================================================================
# Token del bot de Telegram obtenido de @BotFather
# Formato: [BOT_ID]:[TOKEN_HASH]
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# =============================================================================
# 🤖 AI APIS (OPTIONAL - Al menos una recomendada)
# =============================================================================
# Google Gemini API Key (recomendada - modelo Gemini 2.0 Flash)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI API Key (GPT-4o, GPT-4-turbo)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic API Key (Claude 3 Opus/Sonnet)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# 💰 TRADING APIS - CRYPTO (OPTIONAL)
# =============================================================================
# Kraken Exchange API Credentials
# Obtener en: https://www.kraken.com/u/security/api
# Permisos necesarios: Query Funds, Query Open Orders, Query Closed Orders, Create & Modify Orders
KRAKEN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
KRAKEN_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# 📊 TRADING APIS - STOCKS (OPTIONAL)
# =============================================================================
# Alpaca Trading API (para acciones NYSE/NASDAQ)
# Obtener en: https://alpaca.markets/
# Usar Paper Trading API para testing: https://paper-api.alpaca.markets
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXX
ALPACA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# 🗄️ DATABASE (OPTIONAL - Auto-configurado en Replit/Railway)
# =============================================================================
# PostgreSQL Database URL (auto-configurado en Replit)
# Formato: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://user:pass@localhost:5432/omnix_db

# Redis Cache URL (opcional - mejora performance)
# Formato: redis://host:port/db
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 🔐 SECURITY (OPTIONAL - Auto-generados si no se proveen)
# =============================================================================
# Session Secret Key (mínimo 32 caracteres)
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SESSION_SECRET=your-very-long-secret-key-here-min-32-chars

# Encryption Key (mínimo 32 caracteres)
# ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# =============================================================================
# ⚙️ APP SETTINGS (OPTIONAL - Valores por defecto incluidos)
# =============================================================================
# Puerto del servidor web (default: 8000)
PORT=8000

# Host del servidor web (default: 0.0.0.0)
HOST=0.0.0.0

# Habilitar trading de acciones NYSE/NASDAQ (default: true)
# Valores: true | false
STOCK_TRADING_ENABLED=true

# Modo Paper Trading - Trading virtual sin dinero real (default: true)
# Valores: true | false
# IMPORTANTE: Cambiar a false SOLO cuando estés listo para trading real
PAPER_MODE=true

# Nivel de logging (default: INFO)
# Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# 📊 MONITORING (OPTIONAL)
# =============================================================================
# Habilitar métricas de monitoreo (default: true)
ENABLE_METRICS=true

# Puerto para métricas Prometheus (default: 9090)
METRICS_PORT=9090

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
# 1. NUNCA commitear este archivo con valores reales a git
# 2. Usar Replit Secrets para producción (más seguro)
# 3. Variables REQUIRED deben estar configuradas obligatoriamente
# 4. Variables OPTIONAL usan valores por defecto si no se proveen
# 5. Validación automática de formatos al iniciar la aplicación
# 6. Logs claros muestran de dónde se cargó cada variable
#
# Para más información sobre configuración:
# - Ver: omnix_config/env_manager.py
# - Documentación: https://docs.omnix.trading/configuration
# =============================================================================
