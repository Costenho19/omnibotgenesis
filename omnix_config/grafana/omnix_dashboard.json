{
  "dashboard": {
    "title": "OMNIX V5.2 Quantum Ultimate - Trading Dashboard",
    "tags": ["omnix", "trading", "crypto", "quantum"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Trades Executed",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(omnix_trades_total)",
            "legendFormat": "Total Trades"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Win Rate %",
        "type": "gauge",
        "targets": [
          {
            "expr": "omnix_win_rate_percent{mode=\"paper\"}",
            "legendFormat": "Paper Mode"
          },
          {
            "expr": "omnix_win_rate_percent{mode=\"real\"}",
            "legendFormat": "Real Mode"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 40, "color": "yellow"},
                {"value": 55, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Profit/Loss (USD)",
        "type": "stat",
        "targets": [
          {
            "expr": "omnix_pnl_usd{mode=\"paper\"}",
            "legendFormat": "Paper P/L"
          },
          {
            "expr": "omnix_pnl_usd{mode=\"real\"}",
            "legendFormat": "Real P/L"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "thresholds": {
              "steps": [
                {"value": -10000, "color": "red"},
                {"value": 0, "color": "yellow"},
                {"value": 1000, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Bot Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "omnix_bot_uptime_seconds",
            "legendFormat": "Uptime"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Trades Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(omnix_trades_total[5m])",
            "legendFormat": "{{action}} - {{mode}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 6,
        "title": "Win vs Loss Trades",
        "type": "piechart",
        "targets": [
          {
            "expr": "omnix_trades_outcome_total{mode=\"paper\"}",
            "legendFormat": "{{outcome}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 7,
        "title": "Signals by Strategy",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(omnix_signals_total[5m])",
            "legendFormat": "{{strategy}} - {{signal}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 8,
        "title": "Strategy Win Rates",
        "type": "bargauge",
        "targets": [
          {
            "expr": "omnix_strategy_win_rate",
            "legendFormat": "{{strategy}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        }
      },
      {
        "id": 9,
        "title": "Adaptive Omega Weight",
        "type": "graph",
        "targets": [
          {
            "expr": "omnix_adaptive_omega",
            "legendFormat": "Omega (Kalman/Monte Carlo balance)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 10,
        "title": "Hurst Exponent",
        "type": "graph",
        "targets": [
          {
            "expr": "omnix_hurst_exponent",
            "legendFormat": "Hurst (Long Memory Detection)"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 20
        }
      },
      {
        "id": 11,
        "title": "Alpha Stable Index",
        "type": "graph",
        "targets": [
          {
            "expr": "omnix_alpha_stable",
            "legendFormat": "Alpha (Heavy Tail Index)"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 20
        }
      },
      {
        "id": 12,
        "title": "Quantum Momentum Signal",
        "type": "graph",
        "targets": [
          {
            "expr": "omnix_quantum_signal",
            "legendFormat": "Quantum Signal"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": -10,
            "max": 10
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 26
        }
      },
      {
        "id": 13,
        "title": "Kalman Trend Strength",
        "type": "gauge",
        "targets": [
          {
            "expr": "omnix_kalman_trend_strength",
            "legendFormat": "Kalman Trend"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.3, "color": "yellow"},
                {"value": 0.7, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 26
        }
      },
      {
        "id": 14,
        "title": "Black Swan Risk Level",
        "type": "stat",
        "targets": [
          {
            "expr": "omnix_black_swan_risk",
            "legendFormat": "Risk Level"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"value": 0, "text": "LOW"},
              {"value": 1, "text": "MEDIUM"},
              {"value": 2, "text": "HIGH"}
            ],
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 2, "color": "red"}
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 26
        }
      },
      {
        "id": 15,
        "title": "Kraken API Latency (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(omnix_kraken_api_latency_seconds_bucket[5m]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 32
        }
      },
      {
        "id": 16,
        "title": "API Errors",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(omnix_api_errors_total[5m])",
            "legendFormat": "{{service}} - {{error_type}}"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 32
        }
      },
      {
        "id": 17,
        "title": "Balance by Asset",
        "type": "graph",
        "targets": [
          {
            "expr": "omnix_balance_usd{mode=\"paper\"}",
            "legendFormat": "{{asset}} (Paper)"
          },
          {
            "expr": "omnix_balance_usd{mode=\"real\"}",
            "legendFormat": "{{asset}} (Real)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 38
        }
      },
      {
        "id": 18,
        "title": "Monte Carlo Win Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "omnix_monte_carlo_win_rate",
            "legendFormat": "MC Win Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 46
        }
      },
      {
        "id": 19,
        "title": "Auto-Learning Changes Applied",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(omnix_auto_learning_changes_total)",
            "legendFormat": "Total Changes"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 46
        }
      },
      {
        "id": 20,
        "title": "Video Analyses Success Rate",
        "type": "piechart",
        "targets": [
          {
            "expr": "omnix_video_analyses_total",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 46
        }
      }
    ],
    "refresh": "5s",
    "schemaVersion": 36,
    "style": "dark",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "uid": "omnix-v52-quantum",
    "version": 1
  }
}
