modules = ["python-3.11", "python3", "nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "arrow-cpp", "bzip2", "c-blosc", "cairo", "cargo", "ffmpeg", "ffmpeg-full", "fontconfig", "freetype", "ghostscript", "glib", "glibcLocales", "gmp", "gobject-introspection", "gtk3", "harfbuzz", "hdf5", "imagemagick", "imagemagickBig", "lcms2", "libGL", "libGLU", "libffi", "libiconv", "libimagequant", "libjpeg", "libpng", "libsodium", "libtiff", "libuv", "libwebp", "libxcrypt", "lzo", "openjpeg", "openssl", "pango", "pkg-config", "portaudio", "portmidi", "postgresql", "qhull", "railway", "rustc", "sqlite", "tcl", "tk", "xcodebuild", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Code Verification"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard Preview"

[[workflows.workflow]]
name = "Code Verification"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -u verify_code.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Dashboard Preview"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd omnix_dashboard && python -c \"from app import app; app.run(host='0.0.0.0', port=5000, debug=False)\""
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

