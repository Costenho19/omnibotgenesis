modules = ["python-3.11", "python3", "nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "arrow-cpp", "bzip2", "c-blosc", "cairo", "cargo", "ffmpeg", "ffmpeg-full", "fontconfig", "freetype", "ghostscript", "glib", "glibcLocales", "gmp", "gobject-introspection", "gtk3", "harfbuzz", "hdf5", "imagemagick", "imagemagickBig", "lcms2", "libGL", "libGLU", "libev", "libffi", "libiconv", "libimagequant", "libjpeg", "libpng", "libsodium", "libtiff", "libuv", "libwebp", "libxcrypt", "lzo", "openjpeg", "openssl", "pango", "pkg-config", "portaudio", "portmidi", "postgresql", "qhull", "railway", "rustc", "sqlite", "tcl", "tk", "xcodebuild", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Code Verification"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Systemic Router Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Response Validator Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OMNIX Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Governance Integrity Tests"

[[workflows.workflow]]
name = "Code Verification"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && TESTING=true TELEGRAM_BOT_TOKEN=test-token python -m pytest tests/test_code_verification.py tests/test_version_consistency.py tests/test_critical_audit.py -v --tb=short"

[[workflows.workflow]]
name = "Systemic Router Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && TESTING=true TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890 python -m pytest tests/test_systemic_router.py -v --tb=short"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Response Validator Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && TESTING=true TELEGRAM_BOT_TOKEN=test-token python -m pytest tests/test_response_validator.py -v --tb=short"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "OMNIX Web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/omnix_web/start.sh"
waitForPort = 3000

[[workflows.workflow]]
name = "Flask Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd omnix_dashboard && python -m flask run --host=0.0.0.0 --port=5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Governance Integrity Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && TESTING=true TELEGRAM_BOT_TOKEN=test-token python -m pytest tests/test_governance_integrity.py -v --tb=short"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "cd omnix_web && npm ci && npm run build"]
run = ["bash", "-c", "gunicorn --bind=0.0.0.0:${PORT:-5000} --reuse-port --workers=2 --timeout=120 omnix_dashboard.app:app"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
PAPER_MODE = "TRUE"
REDIS_URL = "redis://default:GOZQUHyOucycXwFuMlRXZBWIsblTiXnv@shinkansen.proxy.rlwy.net:32595"
TRADING_PROFILE = "PAPER_OPTIMIZED"
LEGACY_USER_ID = "7014748854"
OMNIX_ADMIN_CLIENT_ID = "omnix-admin"
OMNIX_PILOT_CLIENT_ID = "quant-fund-alpha-01"
OMNIX_DB_URL = "postgresql://postgres:tejVvBMMGjchzTrmygaJlCagobIYWbQB@shuttle.proxy.rlwy.net:32087/railway"
