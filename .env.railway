# OMNIX V5.3 ULTRA - Railway Environment Variables
# Copy these to Railway Dashboard > Variables

# ========================================
# TELEGRAM BOT (REQUIRED)
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ========================================
# AI APIs (RECOMMENDED - Multi-Model AI)
# ========================================
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Optional fallback

# ========================================
# TRADING APIs (FOR REAL TRADING)
# ========================================
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ========================================
# DATABASE (AUTO-CONFIGURED BY RAILWAY)
# ========================================
# Railway will auto-inject DATABASE_URL when you add PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/database

# ========================================
# REDIS (AUTO-CONFIGURED BY RAILWAY)
# ========================================
# Railway will auto-inject REDIS_URL when you add Redis
# REDIS_URL=redis://host:port

# ========================================
# OPTIONAL SERVICES
# ========================================
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here  # Voice synthesis
# STRIPE_SECRET_KEY=your_stripe_secret_key_here    # Payment processing

# ========================================
# SYSTEM CONFIGURATION (AUTO-SET)
# ========================================
# PORT=8080  # Railway auto-sets this
# RAILWAY_ENVIRONMENT=production
# PYTHONUNBUFFERED=1

# ========================================
# TRADING MODE (IMPORTANT!)
# ========================================
# PAPER_MODE=true   # Set to 'false' for REAL trading (use with caution!)
# MAX_POSITION_SIZE_USD=1000
# STOP_LOSS_PCT=0.05
# MAX_DAILY_LOSS_PCT=0.05

# ========================================
# DEPLOYMENT NOTES
# ========================================
# 1. Add PostgreSQL to your Railway project (required)
# 2. Add Redis to your Railway project (required)
# 3. Copy TELEGRAM_BOT_TOKEN, OPENAI_API_KEY, GEMINI_API_KEY
# 4. For REAL trading: Add KRAKEN_API_KEY and KRAKEN_API_SECRET
# 5. Leave DATABASE_URL and REDIS_URL empty - Railway auto-injects them
# 6. Deploy and monitor logs for startup
