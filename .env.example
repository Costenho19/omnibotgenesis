# ============================================
# OMNIX ENTERPRISE BOT - CONFIGURATION
# ============================================

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# AI Model API Keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key
HUGGINGFACE_TOKEN=your_huggingface_token

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/omnix_bot
REDIS_URL=redis://localhost:6379/0

# Crypto Exchange API Keys
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_SECRET_KEY=your_coinbase_secret_key

# Blockchain RPC URLs
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id
BSC_RPC_URL=https://bsc-dataseed.binance.org/
POLYGON_RPC_URL=https://polygon-rpc.com/
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Security & Encryption
SECRET_KEY=your_super_secret_key_for_encryption
JWT_SECRET_KEY=your_jwt_secret_key
ENCRYPTION_KEY=your_32_character_encryption_key

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
MAX_USERS=10000
RATE_LIMIT_PER_MINUTE=60

# Payment Integration
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn_url
PROMETHEUS_PORT=9090

# ============================================
# STOCK TRADING MODULE (V6.0) - ACTIVO
# ============================================
# Activar/Desactivar módulo de bolsa
STOCK_TRADING_ENABLED=true

# Alpaca Markets API (Stock Trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Alpha Vantage API (Stock Market Data)
ALPHA_VANTAGE_API_KEY=demo

# Financial Modeling Prep API (Optional - Fundamental Data)
FMP_API_KEY=your_fmp_api_key_here