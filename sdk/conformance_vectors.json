  "issued_by": "OMNIX QUANTUM LTD",
  "issued_date": "2026-05-17",
  "purpose": "Cross-language parity conformance vectors. Any compliant OMNIX SDK must produce identical output for every vector regardless of implementation language. Closes FVP-INV-007 cross-language gap (identified in VeriSigil AI technical review, May 2026).",
  "invariants_covered": [
    "FVP-INV-007 platform_fingerprint determinism across languages",
    "ATF-INV-006 canonical JSON serialization reproducibility"
  ],
  "adr_references": [
    "ADR-167 (platform key fingerprint)",
    "RFC-ATF-3 (FVP)",
    "ADR-157 rev.2"
  ],
  "algorithm_specs": {
    "key_fingerprint": "fingerprint = \"sha256:\" + sha256(base64decode(key_b64)).hexdigest(). Input: base64-encoded raw public key bytes. Output: \"sha256:\" prefix + lowercase hex digest. No padding, no intermediate encoding.",
    "canonical_json": "Rules: (1) sort object keys A-Z at every nesting level; (2) no whitespace around : or comma; (3) Unicode chars preserved as-is, not \\uXXXX escaped; (4) encode result as UTF-8 bytes before hashing."
  },
